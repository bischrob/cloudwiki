{
  "name": "bischrob/cloudwiki",
  "description": "CloudWiki Nextcloud app",
  "type": "project",
  "license": "AGPL-3.0-or-later",
  "autoload": {
    "psr-4": {
      "OCA\\CloudWiki\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\CloudWiki\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.69",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "lint:php": "php-cs-fixer fix --dry-run --diff",
    "format:php": "php-cs-fixer fix",
    "stan": "phpstan analyse",
    "test:php": "phpunit -c phpunit.xml"
  }
}
